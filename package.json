{
  "name": "idphoto-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv-cli -e .env -- drizzle-kit migrate",
    "db:push": "dotenv-cli -e .env -- drizzle-kit push",
    "db:seed": "dotenv-cli -e .env -- tsx scripts/seed.ts",
    "db:studio": "dotenv-cli -e .env -- drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "nanoid": "^5.1.11",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-safe-action": "^8.5.2",
    "openai": "^6.35.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
